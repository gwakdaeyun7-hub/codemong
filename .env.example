# Copy to .env.local and fill in real values

# ===== Supabase =====
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Postgres connection (Supabase: Project Settings -> Database -> Connection string)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# ===== App URL (이메일 redirect / OAuth callback 의 base URL) =====
# 로컬: http://localhost:3000
# 프로덕션: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== OAuth =====
# Supabase Dashboard -> Authentication -> Providers 에서 Google / Kakao 활성화 후
# 각 Provider 의 Client ID / Secret 을 Supabase Dashboard 에 입력.
# 이 앱 코드에는 OAuth secret 을 직접 두지 않는다 (Supabase 가 대신 보관).
#
# Google: https://console.cloud.google.com/ -> OAuth 2.0 client (Web)
#   - Authorized redirect URI: https://<your-project>.supabase.co/auth/v1/callback
# Kakao: https://developers.kakao.com/ -> 내 애플리케이션 -> 카카오 로그인
#   - Redirect URI: https://<your-project>.supabase.co/auth/v1/callback
#   - 동의항목: 카카오계정(이메일) [필수], 닉네임 [선택]
#
# Supabase Dashboard -> Authentication -> URL Configuration:
#   - Site URL: ${NEXT_PUBLIC_SITE_URL}
#   - Redirect URLs: ${NEXT_PUBLIC_SITE_URL}/auth/callback
